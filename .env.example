# PostgreSQL connection string used by Prisma.
# For docker-compose: postgresql://morohub:morohub@postgres:5432/morohub?schema=public
# For local dev (native Postgres): postgresql://morohub:morohub@localhost:5432/morohub?schema=public
DATABASE_URL="postgresql://morohub:morohub@localhost:5432/morohub?schema=public"

# Auth.js (NextAuth v5) — 32+ byte random string.
# Generate: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-32-byte-random-string"

# Trust the host header when running behind an ingress/load balancer.
AUTH_TRUST_HOST=true

# Seed credentials (used by prisma/seed.ts). Override for non-local environments.
SEED_ADMIN_EMAIL="admin@morohub.local"
SEED_ADMIN_PASSWORD="MoroHub@12345"
